# =============================================================================
#  DoH Proxy v2 — 用户配置文件
#
#  使用方式：
#    1. 编辑本文件中的参数
#    2. USE_CONFIG_JS=false 时运行 node scripts/build-config.cjs 生成 config.js
#       USE_CONFIG_JS=true 时脚本会直接使用现有 config.js，不生成新文件
#    3. 部署到 Cloudflare Workers
#
#  预设上游的 URL 和 EDNS 能力已内置，无需手写。
# =============================================================================


# ─────────────────────────────────────────────────────────────────────────────
#  上游配置
# ─────────────────────────────────────────────────────────────────────────────

# 预设上游开关（true = 启用 / false = 禁用）
GOOGLE=true
CLOUDFLARE_PUBLIC=true
QUAD9=true
ADGUARD=true
OPENDNS=true
YANDEX=false
DNSPOD=false
ALIDNS=false
360=false
NEXTDNS=true

# 日志级别: debug / info / warn / error / none（默认 info，生产建议 warn）
LOG_LEVEL=info

# 自定义上游（格式：CUSTOM_<名称>=<DoH URL>）
# CUSTOM_MY=https://my-doh.example.com/dns-query


# ─────────────────────────────────────────────────────────────────────────────
#  EDNS / ECS / 黑名单
# ─────────────────────────────────────────────────────────────────────────────

# ECS 子网前缀长度（数值越大，暴露的位置越精确；数值越小，隐私性相对更高）
ECS_PREFIX4=24
ECS_PREFIX6=56

# 应答 IP 黑名单（CIDR 空格分隔，命中后整包丢弃）
BLOCKED_CIDRS=127.0.0.0/8 0.0.0.0/32 ::/128 ::1/128

# AUTO 竞速并发上游数（0=全部，Free 计划建议 4，留槽位给 AUTO 2 和 ECH）
AUTO_CONCURRENCY=6


# =============================================================================
#  地区优化解析
# 每个地区一块配置，注释/取消注释整块即可开关
# REGION=XX 仅作可读标题和构建标识，实际地区匹配由 Cloudflare request.cf.country 决定
# 每个地区一块配置，注释/取消注释整块即可开关
# =============================================================================

# 配置文件模式: false=从 .env 构建 config.js / true=直接使用现有 config.js，不生成新文件
USE_CONFIG_JS=false

# 全局默认 CF 优选域名；单地区 REGION_XX_PREFERRED_CF 会覆盖它
# PREFERRED_CF_DOMAIN=cf.example.com

REGION=CN
REGION_CN_PREFERRED_CF=cf.090227.xyz
REGION_CN_PREFERRED_CFT=worker.cloudfront.182682.xyz
REGION_CN_PREFERRED_VRC=worker.vercel.182682.xyz
REGION_CN_REMAP=twimg.com twitter.com x.com t.co pixiv.net www.pixiv.net imp.pixiv.net
REGION_CN_ECH=true
REGION_CN_GOOGLE=true

#REGION=RU
#REGION_RU_PREFERRED_CF=cf.877774.xyz
#REGION_RU_REMAP=twimg.com twitter.com x.com t.co
#REGION_RU_ECH=true
